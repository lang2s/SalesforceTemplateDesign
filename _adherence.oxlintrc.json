{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/buttons/**",
              "components/containers/**",
              "components/data/**",
              "components/display/**",
              "components/feedback/**",
              "components/forms/**",
              "components/navigation/**",
              "components/overlays/**",
              "components/progress/**",
              "crm-builder/**",
              "ui_kits/lightning-crm/**",
              "ui_kits/lightning-crm/data/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Salesforce Sans|Public Sans|Roboto Mono|Material Symbols Rounded))/i]",
        "message": "Font not provided by the design system. Available: Salesforce Sans, Public Sans, Roboto Mono, Material Symbols Rounded."
      },
      {
        "selector": "JSXOpeningElement[name.name='AccordionSection'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|label|content|key|ref|className|style|children)$/]",
        "message": "<AccordionSection> doesn't accept that prop. Declared props: id, label, content."
      },
      {
        "selector": "JSXOpeningElement[name.name='Alert'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|iconName|onClose|children|className|style|key|ref|className|style|children)$/]",
        "message": "<Alert> doesn't accept that prop. Declared props: variant, iconName, onClose, children, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|initials|iconName|size|variant|alt|className|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: src, initials, iconName, size, variant, alt, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:circle|square)$/]",
        "message": "<Avatar> variant must be one of 'circle' | 'square'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|children|variant|className|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: label, children, variant, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='BreadcrumbItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|href|onClick|key|ref|className|style|children)$/]",
        "message": "<BreadcrumbItem> doesn't accept that prop. Declared props: label, href, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|children|variant|size|iconName|iconPosition|disabled|stretch|type|onClick|className|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: label, children, variant, size, iconName, iconPosition, disabled, stretch, type, onClick, className, style."
